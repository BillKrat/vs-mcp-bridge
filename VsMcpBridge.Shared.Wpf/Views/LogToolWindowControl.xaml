<UserControl x:Class="VsMcpBridge.Shared.Wpf.Views.LogToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:VsMcpBridge.Shared.Models;assembly=VsMcpBridge.Shared"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400"
             Background="{DynamicResource VsBrush.Window}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </UserControl.Resources>

  <Grid Margin="4">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Margin="0,0,0,8"
            Padding="8"
            BorderBrush="{DynamicResource VsBrush.CommandBarBorder}"
            BorderThickness="1">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Margin="0,0,0,8"
                  Padding="8"
                  BorderBrush="{DynamicResource VsBrush.CommandBarBorder}"
                  BorderThickness="1"
                  Visibility="{Binding HasLastSubmittedRequest, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding LastSubmittedRequestText, StringFormat=> {0}}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource VsBrush.WindowText}" />
          </Border>

          <Border Margin="0,0,0,8"
                  Padding="8"
                  BorderBrush="{DynamicResource VsBrush.CommandBarBorder}"
                  BorderThickness="1"
                  Visibility="{Binding IsRequestInProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
              <TextBlock Text="Working"
                         Margin="0,0,0,6"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource VsBrush.WindowText}" />
              <TextBlock Text="{Binding ActivitySummary}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource VsBrush.WindowText}" />
              <ProgressBar Margin="0,8,0,0"
                           Height="8"
                           IsIndeterminate="True" />
            </StackPanel>
          </Border>

          <Border Margin="0,0,0,8"
                  Padding="8"
                  BorderBrush="{DynamicResource VsBrush.CommandBarBorder}"
                  BorderThickness="1"
                  Visibility="{Binding HasPendingApproval, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
              <TextBlock Text="Review ready"
                         Margin="0,0,0,6"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource VsBrush.WindowText}" />
              <TextBlock Text="{Binding ActivitySummary}"
                         Margin="0,0,0,6"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource VsBrush.WindowText}" />
              <TextBlock Text="{Binding ActivityMetricsSummary}"
                         Margin="0,0,0,6"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource VsBrush.WindowText}"
                         Visibility="{Binding HasActivityMetricsSummary, Converter={StaticResource BooleanToVisibilityConverter}}" />

              <TextBlock Text="Affected Files"
                         Margin="0,0,0,4"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource VsBrush.WindowText}"
                         Visibility="{Binding HasPendingApprovalIncludedFiles, Converter={StaticResource BooleanToVisibilityConverter}}" />
              <ItemsControl ItemsSource="{Binding PendingApprovalIncludedFiles}"
                            Visibility="{Binding HasPendingApprovalIncludedFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBox Margin="0,0,0,4"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding Mode=OneWay}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="Reviewed Changes"
                         Margin="0,6,0,4"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource VsBrush.WindowText}"
                         Visibility="{Binding HasPendingApprovalReviewedChanges, Converter={StaticResource BooleanToVisibilityConverter}}" />
              <ItemsControl ItemsSource="{Binding PendingApprovalReviewedChanges}"
                            Visibility="{Binding HasPendingApprovalReviewedChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type models:ProposalReviewedChange}">
                    <Border Margin="0,0,0,6"
                            Padding="6"
                            BorderBrush="{DynamicResource VsBrush.CommandBarBorder}"
                            BorderThickness="1">
                      <StackPanel>
                        <TextBlock Text="{Binding SequenceNumber, StringFormat=Change {0}}"
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource VsBrush.WindowText}" />
                        <TextBlock Text="{Binding OriginalSegment, StringFormat=From: {0}}"
                                   Margin="0,0,0,2"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource VsBrush.WindowText}" />
                        <TextBlock Text="{Binding UpdatedSegment, StringFormat=To: {0}}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource VsBrush.WindowText}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <StackPanel Orientation="Horizontal"
                          Margin="0,8,0,0">
                <Button Content="Keep"
                        Margin="0,0,8,0"
                        Command="{Binding ApproveCommand}" />
                <Button Content="Reject"
                        Command="{Binding RejectCommand}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Margin="0,0,0,8"
                  Padding="8"
                  BorderBrush="{DynamicResource VsBrush.CommandBarBorder}"
                  BorderThickness="1"
                  Visibility="{Binding HasLastCompletedProposalPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
              <TextBlock Text="Result"
                         Margin="0,0,0,6"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource VsBrush.WindowText}" />
              <TextBlock Text="{Binding ActivitySummary}"
                         Margin="0,0,0,6"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource VsBrush.WindowText}" />
              <TextBlock Text="{Binding ActivityMetricsSummary}"
                         Margin="0,0,0,6"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource VsBrush.WindowText}"
                         Visibility="{Binding HasActivityMetricsSummary, Converter={StaticResource BooleanToVisibilityConverter}}" />

              <TextBlock Text="Affected Files"
                         Margin="0,0,0,4"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource VsBrush.WindowText}"
                         Visibility="{Binding HasLastCompletedProposalIncludedFiles, Converter={StaticResource BooleanToVisibilityConverter}}" />
              <ItemsControl ItemsSource="{Binding LastCompletedProposalIncludedFiles}"
                            Visibility="{Binding HasLastCompletedProposalIncludedFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBox Margin="0,0,0,4"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding Mode=OneWay}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Button Content="Open Git Changes"
                      Margin="0,8,0,0"
                      HorizontalAlignment="Left"
                      Command="{Binding OpenGitChangesCommand}" />
            </StackPanel>
          </Border>

          <Expander Header="Advanced"
                    Margin="0,0,0,8"
                    IsExpanded="False"
                    Visibility="Collapsed">
            <StackPanel Margin="0,8,0,0">
              <Expander Header="Detailed Review"
                        Visibility="{Binding HasPendingApproval, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="0,8,0,0">
                  <TextBlock Text="{Binding PendingApprovalDescription}"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource VsBrush.WindowText}" />
                  <Grid Margin="0,8,0,0"
                        Visibility="{Binding HasPendingApprovalRangePreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="8" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Original Segment"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource VsBrush.WindowText}" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Updated Segment"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource VsBrush.WindowText}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             MinHeight="60"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding PendingApprovalOriginalSegment, Mode=OneWay}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="2"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             MinHeight="60"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding PendingApprovalUpdatedSegment, Mode=OneWay}" />
                  </Grid>
                </StackPanel>
              </Expander>

              <Expander Header="Detailed Proposal Editor"
                        Visibility="{Binding ShowProposalEditor, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="0,8,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Original Text"
                               Margin="0,0,0,2"
                               Foreground="{DynamicResource VsBrush.WindowText}" />
                    <TextBox Grid.Row="1"
                             AcceptsReturn="True"
                             MinHeight="100"
                             IsReadOnly="{Binding IsProposalOriginalTextReadOnly}"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding ProposalOriginalText, UpdateSourceTrigger=PropertyChanged}" />
                  </Grid>
                  <GridSplitter Grid.Column="1"
                                Width="5"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{DynamicResource VsBrush.CommandBarBorder}"
                                ResizeDirection="Columns"
                                ResizeBehavior="PreviousAndNext" />
                  <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Proposed Text"
                               Margin="0,0,0,2"
                               Foreground="{DynamicResource VsBrush.WindowText}" />
                    <TextBox Grid.Row="1"
                             AcceptsReturn="True"
                             MinHeight="100"
                             IsReadOnly="{Binding IsProposalProposedTextReadOnly}"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding ProposalProposedText, UpdateSourceTrigger=PropertyChanged}" />
                  </Grid>
                </Grid>
              </Expander>

              <Expander Header="Last Completed Details"
                        Visibility="{Binding HasLastCompletedProposalPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="0,8,0,0">
                  <Grid Margin="0,0,0,8"
                        Visibility="{Binding HasLastCompletedProposalRangePreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="8" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Original Segment"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource VsBrush.WindowText}" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Updated Segment"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource VsBrush.WindowText}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             MinHeight="60"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding LastCompletedProposalOriginalSegment, Mode=OneWay}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="2"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             MinHeight="60"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             Text="{Binding LastCompletedProposalUpdatedSegment, Mode=OneWay}" />
                  </Grid>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="8" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                      </Grid.RowDefinitions>
                      <TextBlock Grid.Row="0"
                                 Text="Original Text"
                                 Margin="0,0,0,4"
                                 Foreground="{DynamicResource VsBrush.WindowText}" />
                      <TextBox Grid.Row="1"
                               IsReadOnly="True"
                               AcceptsReturn="True"
                               MinHeight="100"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto"
                               TextWrapping="NoWrap"
                               FontFamily="Consolas"
                               Text="{Binding LastCompletedProposalOriginalText, Mode=OneWay}" />
                    </Grid>
                    <Grid Grid.Column="2">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                      </Grid.RowDefinitions>
                      <TextBlock Grid.Row="0"
                                 Text="Updated Text"
                                 Margin="0,0,0,4"
                                 Foreground="{DynamicResource VsBrush.WindowText}" />
                      <TextBox Grid.Row="1"
                               IsReadOnly="True"
                               AcceptsReturn="True"
                               MinHeight="100"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto"
                               TextWrapping="NoWrap"
                               FontFamily="Consolas"
                               Text="{Binding LastCompletedProposalUpdatedText, Mode=OneWay}" />
                    </Grid>
                  </Grid>
                </StackPanel>
              </Expander>

              <Expander Header="Log">
                <StackPanel Margin="0,8,0,0">
                  <TextBox IsReadOnly="True"
                           TextWrapping="Wrap"
                           MinHeight="80"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Disabled"
                           FontFamily="Consolas"
                           FontSize="12"
                           Background="Transparent"
                           Foreground="{DynamicResource VsBrush.WindowText}"
                           BorderThickness="0"
                           Text="{Binding LogText, Mode=OneWay}" />
                  <StackPanel Orientation="Horizontal"
                              Margin="0,8,0,0">
                    <TextBlock Text="Log Level:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Foreground="{DynamicResource VsBrush.WindowText}" />
                    <ComboBox ItemsSource="{Binding AvailableLogLevels}"
                              SelectedItem="{Binding SelectedLogLevel}"
                              MinWidth="110" />
                  </StackPanel>
                </StackPanel>
              </Expander>
            </StackPanel>
          </Expander>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="1"
            Padding="8"
            BorderBrush="{DynamicResource VsBrush.CommandBarBorder}"
            BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.Column="0"
              Margin="0,0,8,8">
          <TextBox MinHeight="72"
                   MaxHeight="160"
                   AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled"
                   TextWrapping="Wrap"
                   Text="{Binding RequestInputText, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Margin="6,6,24,8"
                     IsHitTestVisible="False"
                     Text="Describe what you want changed..."
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource VsBrush.GrayTextKey}">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasRequestInputText}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <Button Grid.Row="0"
                Grid.Column="1"
                Width="52"
                Height="36"
                VerticalAlignment="Top"
                Content="Send"
                ToolTip="Send"
                Command="{Binding SubmitProposalCommand}" />

        <StackPanel Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2">
          <TextBlock Text="{Binding ProposalSelectionSummary}"
                     Margin="0,0,0,4"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource VsBrush.WindowText}" />
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Row="0"
                     Grid.Column="0"
                     Grid.ColumnSpan="3"
                     Margin="0,0,0,8"
                     MinHeight="56"
                     MaxHeight="100"
                     ItemsSource="{Binding ProposalSelectedFiles}"
                     SelectedItem="{Binding ProposalFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBox Grid.Row="1"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     Text="{Binding ProposalFilePath, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    Content="Add File"
                    Command="{Binding BrowseProposalFileCommand}" />
            <StackPanel Grid.Row="1"
                        Grid.Column="2"
                        Orientation="Horizontal">
              <Button Content="Remove Selected"
                      Margin="0,0,8,0"
                      Command="{Binding RemoveProposalFileCommand}" />
              <Button Content="Reset"
                      Margin="0,0,8,0"
                      Command="{Binding ResetProposalCommand}" />
              <Button Content="New Chat"
                      Command="{Binding NewChatCommand}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
