<UserControl x:Class="VsMcpBridge.Vsix.ToolWindows.LogToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400"
             Background="{DynamicResource VsBrush.Window}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Log output -->
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <TextBox IsReadOnly="True"
               TextWrapping="Wrap"
               FontFamily="Consolas"
               FontSize="12"
               Background="Transparent"
               Foreground="{DynamicResource VsBrush.WindowText}"
               BorderThickness="0"
               Text="{Binding LogText, Mode=OneWay}" />
    </ScrollViewer>

    <!-- Approval bar -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4">
      <TextBlock VerticalAlignment="Center" Margin="0,0,8,0"
                 Text="{Binding PendingApprovalDescription}"
                 Foreground="{DynamicResource VsBrush.WindowText}" />
      <Button Content="Approve" Margin="0,0,4,0"
              Command="{Binding ApproveCommand}" />
      <Button Content="Reject"
              Command="{Binding RejectCommand}" />
    </StackPanel>
  </Grid>
</UserControl>
