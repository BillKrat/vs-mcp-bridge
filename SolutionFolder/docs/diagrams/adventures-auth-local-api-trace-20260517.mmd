sequenceDiagram
    autonumber
    participant Caller as "Local API caller / test harness"
    participant Group as "Minimal API /auth endpoint group"
    participant Handler as "Thin endpoint handler"
    participant ApiService as "IAdventuresAuthApiService"
    participant DecisionService as "IAdventuresAuthDecisionService"
    participant Audit as "Redaction / audit boundary"
    participant Response as "Structured API response"

    Caller->>Group: "POST /auth/login<br/>valid local dev credential"
    Group->>Handler: "AdventuresAuthEndpointHandlers.Login"
    Handler->>ApiService: "Login(request)"
    ApiService->>DecisionService: "Login(AdventuresAuthRequest)"
    DecisionService->>Audit: "AdventuresAuth.RequestReceived<br/>AdventuresAuth.LoginEvaluated<br/>AdventuresAuth.AccessAllowed"
    DecisionService-->>ApiService: "Allowed + local principal/session placeholder"
    ApiService-->>Response: "Allowed<br/>ReasonCode=DevCredentialAccepted"

    Caller->>Group: "POST /auth/login<br/>invalid credential"
    Group->>Handler: "Login"
    Handler->>ApiService: "Login(request)"
    ApiService->>DecisionService: "Login(AdventuresAuthRequest)"
    DecisionService->>Audit: "AdventuresAuth.AccessDenied"
    ApiService-->>Response: "Denied<br/>ReasonCode=DevCredentialRejected"

    Caller->>Group: "POST /auth/validate<br/>valid or invalid local session"
    Group->>Handler: "Validate"
    Handler->>ApiService: "Validate(request)"
    ApiService->>DecisionService: "ValidateSession(AdventuresAuthRequest)"
    DecisionService->>Audit: "AdventuresAuth.SessionValidated"
    ApiService-->>Response: "Allowed or Denied"

    Caller->>Group: "GET /auth/me<br/>valid local session"
    Group->>Handler: "CurrentPrincipal"
    Handler->>ApiService: "CurrentPrincipal(request)"
    ApiService->>DecisionService: "CurrentPrincipal(AdventuresAuthRequest)"
    DecisionService-->>ApiService: "Current principal placeholder"
    ApiService-->>Response: "Principal.Subject=local-dev-user"

    Caller->>Group: "POST /auth/logout"
    Group->>Handler: "Logout"
    Handler->>ApiService: "Logout(request)"
    ApiService->>DecisionService: "Logout(AdventuresAuthRequest)"
    DecisionService-->>ApiService: "LocalSessionInvalidated"
    ApiService-->>Response: "Session placeholder invalidated"

    Caller->>Group: "POST /auth/login<br/>secret-like marker"
    Group->>Handler: "Login"
    Handler->>ApiService: "Login(request)"
    ApiService->>DecisionService: "Login(AdventuresAuthRequest)"
    DecisionService->>Audit: "BridgeSecurityRedactor<br/>AdventuresAuth.SecretRedacted"
    ApiService-->>Response: "SecretsRedacted=true<br/>no raw secret/token values"
